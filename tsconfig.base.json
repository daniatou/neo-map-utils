{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@neo-maps/leaflet-layer-panel": ["packages/core/src/index.ts"],
      "@neo-maps/leaflet-layer-panel-angular": ["packages/adapter-angular/src/index.ts"],
      "@neo-maps/leaflet-layer-panel-react": ["packages/adapter-react/src/index.ts"],
      "@neo-maps/leaflet-layer-panel-vue": ["packages/adapter-vue/src/index.ts"],
      "@neo-maps/layer-panel-headless": ["packages/ui-headless/src/index.ts"],
      "@neo-maps/layer-panel-icons": ["packages/icons/src/index.ts"],
      "@neo-maps/layer-panel-theme": ["packages/theme/src/index.ts"],
      "@neo-maps/layer-panel-utils": ["packages/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}

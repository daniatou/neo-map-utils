{
  "name": "adapter-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/adapter-angular/src",
  "projectType": "library",
  "tags": ["scope:angular", "type:adapter"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:ng-packagr",
      "outputs": ["{workspaceRoot}/dist/packages/adapter-angular"],
      "options": {
        "project": "packages/adapter-angular/ng-package.json"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "config": "packages/adapter-angular/vite.config.ts"
      }
    }
  }
}

{
  "name": "icons",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/icons/src",
  "projectType": "library",
  "tags": ["scope:sdk", "type:icons"],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/icons/tools/generate-icons.mjs"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/icons",
        "main": "packages/icons/src/index.ts",
        "tsConfig": "packages/icons/tsconfig.lib.json"
      }
    }
  }
}
